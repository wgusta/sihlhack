{
  "name": "sihlhack",
  "version": "1.0.0",
  "description": "Participant-oriented energy hackathon in Switzerland building the Sihlicon Hub (Battery + Compute + Heat + Resilience).",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app/dashboard/sim/page.tsx components/sim/SimulationTuningPanel.tsx components/sim3d lib/sim/constants.ts lib/sim/scene-mapper.ts lib/sim/featureRegistry.ts types/sim.ts tests/e2e/sim-3d.smoke.spec.ts playwright.config.ts",
    "lint:all": "eslint .",
    "test:sim:smoke": "playwright test tests/e2e/sim-3d.smoke.spec.ts --project=chromium",
    "test:sim:smoke:install": "playwright install chromium",
    "check:design-tokens": "node scripts/verify-design-tokens.mjs",
    "lint:tokens": "node scripts/lint-token-colors.mjs",
    "postinstall": "node scripts/sync-design-assets.mjs",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wgusta/sihlhack.git"
  },
  "keywords": [
    "hackathon",
    "sihl-valley",
    "historical-data",
    "digitalization"
  ],
  "author": "sihlhack team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wgusta/sihlhack/issues"
  },
  "homepage": "https://github.com/wgusta/sihlhack#readme",
  "dependencies": {
    "@sihliconvalley/design-tokens": "file:../sihliconvalley-design-tokens",
    "@heroicons/react": "^2.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@stripe/stripe-js": "^8.6.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@vercel/blob": "^2.0.0",
    "@vercel/postgres": "^0.10.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "leva": "^0.10.1",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "resend": "^6.6.0",
    "stripe": "^20.1.0",
    "swr": "^2.3.8",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
